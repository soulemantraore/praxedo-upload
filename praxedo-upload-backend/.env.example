# =====================================================================
# praxedo-upload-backend - variables d'environnement (exemple)
#
# Copiez ce fichier en .env et adaptez les valeurs. .env est ignore par
# Git : n'y mettez jamais de secret reel dans le depot.
#
# docker-compose lit .env automatiquement. Pour un run direct (mvn /
# java), exportez d'abord ces variables (ex. `set -a; . ./.env; set +a`).
# Toutes ont une valeur par defaut dans application*.yml : ce fichier
# documente ce qui est surchargeable.
# =====================================================================

# --- Commun -----------------------------------------------------------
# Profil actif : local | test | gcp (defaut applicatif : local en dev).
SPRING_PROFILES_ACTIVE=local
# Port HTTP expose par l'application.
SERVER_PORT=8080

# --- Profils local / test (aucune dependance externe) -----------------
# Repertoire disque du stockage local (proxy qui simule GCS).
STORAGE_LOCAL_DIR=./data/uploads
# URL de base publique utilisee pour construire les URLs d'upload/download.
PUBLIC_BASE_URL=http://localhost:8080

# --- Profil gcp (adapters reels) --------------------------------------
# Google Cloud Storage : bucket des fichiers.
GCS_BUCKET=praxedo-upload-files
# Cloud SQL / PostgreSQL (via Cloud SQL Auth Proxy en prod -> localhost).
DB_URL=jdbc:postgresql://localhost:5432/praxedo
DB_USER=praxedo
DB_PASSWORD=change-me
# ClamAV (clamd) : hote/port du demon d'analyse (sidecar en prod).
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Pub/Sub : projet GCP + topic des demandes de scan.
GCP_PROJECT_ID=praxedo-upload
PUBSUB_SCAN_TOPIC=scan-requests
# Credentials GCP pour un run local en profil gcp (chemin d'une cle de
# compte de service). En Cloud Run, l'identite du service suffit -> a laisser vide.
GOOGLE_APPLICATION_CREDENTIALS=
